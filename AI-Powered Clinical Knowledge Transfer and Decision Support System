      "source": [
        "import re\n",
        "\n",
        "def extract_query_keywords(query):\n",
        "    \"\"\"\n",
        "    Extracts key terms (suspected diagnoses, main symptoms) from a junior doctor's free-text query.\n",
        "\n",
        "    Args:\n",
        "        query (str): The junior doctor's free-text query.\n",
        "\n",
        "    Returns:\n",
        "        dict: A dictionary containing 'diagnosis' (str) and 'symptoms' (list of str).\n",
        "    \"\"\"\n",
        "    extracted_keywords = {\n",
        "        'diagnosis': 'Not Found',\n",
        "        'symptoms': []\n",
        "    }\n",
        "\n",
        "    # 1. Extract suspected diagnosis\n",
        "    # Look for patterns like \"Suspecting X\" or \"Impression: X\"\n",
        "    diagnosis_patterns = [\n",
        "        r\"Suspecting\\s+([\\w\\s]+?)(?:\\.|\\?|$)\",\n",
        "        r\"Impression:\\s*([\\w\\s]+?)(?:\\.|\\?|$)\"\n",
        "    ]\n",
        "    for pattern in diagnosis_patterns:\n",
        "        match = re.search(pattern, query, re.IGNORECASE)\n",
        "        if match:\n",
        "            extracted_keywords['diagnosis'] = match.group(1).strip()\n",
        "            break\n",
        "\n",
        "    # 2. Extract key symptoms\n",
        "    # Look for patterns like \"Patient presents with Y\" or \"complains of Z\"\n",
        "    symptoms_patterns = [\n",
        "        r\"Patient presents with\\s+(.*?)(?:\\.|and|Suspecting|complains of|$)\",\n",
        "        r\"complains of\\s+(.*?)(?:\\.|and|Suspecting|Patient presents with|$)\"\n",
        "    ]\n",
        "    all_symptoms_found = []\n",
        "    for pattern in symptoms_patterns:\n",
        "        matches = re.findall(pattern, query, re.IGNORECASE)\n",
        "        for m in matches:\n",
        "            # Split by common delimiters if multiple symptoms are listed in one match\n",
        "            split_symptoms = [s.strip() for s in re.split(r',|and', m) if s.strip()]\n",
        "            all_symptoms_found.extend(split_symptoms)\n",
        "\n",
        "    if all_symptoms_found:\n",
        "        extracted_keywords['symptoms'] = list(set(all_symptoms_found)) # Remove duplicates\n",
        "\n",
        "    return extracted_keywords\n",
        "\n",
        "# Test the function with a sample query\n",
        "sample_query_keyword_extraction = \"Patient presents with severe abdominal pain, fever, and nausea. Suspecting appendicitis. What are the next steps?\"\n",
        "extracted_terms = extract_query_keywords(sample_query_keyword_extraction)\n",
