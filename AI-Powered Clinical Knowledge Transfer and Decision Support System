        "        r\"Suspecting\\s+([\\w\\s]+?)(?:\\.|\\?|\\s*What|\\s*How|$)\", # Added non-greedy match and expanded stop words\n",
        "        r\"Impression:\\s*([\\w\\s]+?)(?:\\.|\\?|\\s*What|\\s*How|$)\", # Added non-greedy match and expanded stop words\n",
        "        r\"diagnosis of\\s+([\\w\\s]+?)(?:\\.|\\?|\\s*What|\\s*How|$)\",\n",
        "        r\"diagnosed with\\s+([\\w\\s]+?)(?:\\.|\\?|\\s*What|\\s*How|$)\"\n",
        "    ]\n",
        "    for pattern in diagnosis_patterns:\n",
        "        match = re.search(pattern, query, re.IGNORECASE)\n",
        "        if match:\n",
        "            extracted_keywords['diagnosis'] = match.group(1).strip()\n",
        "            break\n",
        "\n",
        "    # 2. Extract key symptoms\n",
        "    # Capture everything between a start phrase and a potential end phrase/diagnosis phrase\n",
        "    symptoms_patterns = [\n",
        "        r\"(?:Patient presents with|presents with|complains of|reports)\\s*(.*?)(?=\\.|Suspecting|Impression|diagnosis of|diagnosed with|What are|How to|$)\",\n",
