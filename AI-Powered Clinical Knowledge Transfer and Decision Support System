        "def filter_candidate_cases(query_keywords, original_df, decoders_map):\n",
        "    current_filtered_df = original_df.copy()\n",
        "\n",
        "    # 1. Filter by diagnosis if found and decodable\n",
        "    query_diagnosis = query_keywords['diagnosis']\n",
        "    diagnosis_filtered_applied = False\n",
        "    if query_diagnosis != 'Not Found' and 'Diagnosis' in decoders_map:\n",
        "        diagnosis_encoder = decoders_map['Diagnosis']\n",
        "        try:\n",
        "            # Encode the query diagnosis string to its numerical representation\n",
        "            # LabelEncoder expects exact matches, remove .lower() for transformation\n",
        "            encoded_query_diagnosis = diagnosis_encoder.transform([query_diagnosis])[0] # Removed .lower()\n",
        "            # Filter the DataFrame based on the encoded diagnosis\n",
        "            current_filtered_df = current_filtered_df[current_filtered_df['Diagnosis'] == encoded_query_diagnosis]\n",
        "            diagnosis_filtered_applied = True\n",
        "            print(f\"Filtered by diagnosis '{query_diagnosis}' (encoded: {encoded_query_diagnosis}). Remaining cases: {len(current_filtered_df)}\")\n",
        "        except ValueError:\n",
        "            print(f\"Warning: Query diagnosis '{query_diagnosis}' not found in known diagnoses. Proceeding without diagnosis filter for now.\")\n",
        "\n",
        "    # 2. Filter by symptoms if found\n",
        "    query_symptoms = query_keywords['symptoms']\n",
        "    if query_symptoms and not current_filtered_df.empty:\n",
        "        # Use raw_data_df's 'Symptoms' column for string-based symptom matching\n",
        "        indices_to_check = current_filtered_df.index\n",
        "        raw_symptoms_for_candidates = raw_data_df.loc[indices_to_check, 'Symptoms']\n",
        "\n",
        "        # Create a regex pattern to match any of the symptoms\n",
        "        symptoms_pattern = '|'.join([re.escape(symptom) for symptom in query_symptoms])\n",
        "\n",
        "        # Find which of these raw symptoms columns contain the pattern (case-insensitive)\n",
        "        symptom_matches_indices = raw_symptoms_for_candidates[\n",
        "            raw_symptoms_for_candidates.str.contains(symptoms_pattern, case=False, na=False)\n",
        "        ].index\n",
