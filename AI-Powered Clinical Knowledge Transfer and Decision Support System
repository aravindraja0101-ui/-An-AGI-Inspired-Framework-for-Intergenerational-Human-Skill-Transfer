        "patient_parameters = all_numerical_features + patient_categorical_features # Combine patient numerical and categorical features\n",
        "junior_doctor_parameters = junior_numerical_features + junior_categorical_features # Combine junior doctor numerical and categorical features\n",
        "expert_parameters = expert_numerical_features + expert_categorical_features # Combine expert numerical and categorical features\n",
        "\n",
        "patient_features_set = set(patient_parameters)\n",
        "junior_features_set = set(junior_doctor_parameters)\n",
        "expert_features_set = set(expert_parameters + expert_text_features)\n",
        "\n",
        "patient_junior_correlations = []\n",
        "patient_expert_correlations = []\n",
        "junior_expert_correlations = []\n",
        "\n",
        "def get_feature_group(feature):\n",
        "    if feature in patient_features_set:\n",
        "        return 'Patient'\n",
        "    elif feature in junior_features_set:\n",
        "        return 'Junior_Doctor'\n",
        "    elif feature in expert_features_set:\n",
        "        return 'Expert'\n",
        "    else:\n",
        "        return 'Unknown'\n",
        "\n",
        "# Filter out text similarity relationships from relationships_df for cross-group analysis\n",
        "filtered_relationships_df = relationships_df[relationships_df['Type'] != 'High Text Similarity']\n",
        "\n",
        "for index, row in filtered_relationships_df.iterrows():\n",
        "    f1 = row['Feature1']\n",
        "    f2 = row['Feature2']\n",
        "    f1_group = get_feature_group(f1)\n",
        "    f2_group = get_feature_group(f2)\n",
        "\n",
        "    if f1_group != 'Unknown' and f2_group != 'Unknown' and f1_group != f2_group:\n",
        "        if (f1_group == 'Patient' and f2_group == 'Junior_Doctor') or \\\n",
        "           (f1_group == 'Junior_Doctor' and f2_group == 'Patient'):\n",
        "            patient_junior_correlations.append(row.to_dict())\n",
        "        elif (f1_group == 'Patient' and f2_group == 'Expert') or \\\n",
        "             (f1_group == 'Expert' and f2_group == 'Patient'):\n",
        "            patient_expert_correlations.append(row.to_dict())\n",
        "        elif (f1_group == 'Junior_Doctor' and f2_group == 'Expert') or \\\n",
        "             (f1_group == 'Expert' and f2_group == 'Junior_Doctor'):\n",
        "            junior_expert_correlations.append(row.to_dict())\n",
        "\n",
        "patient_junior_df = pd.DataFrame(patient_junior_correlations)\n",
        "if not patient_junior_df.empty:\n",
